@model IEnumerable<Aluno>

@{
    ViewData["Title"] = "Alunos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Alunos</h1>
    <a asp-action="Create" class="btn btn-success">Novo aluno</a>
</div>

<table class="table table-striped table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Foto</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Matricula</th>
            <th>Curso</th>
            <th>Disciplina</th>
            <th class="text-center">Acoes</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var aluno in Model)
            {
                <tr>
                    <td><div class="d-flex right-align">
                        <img src="~/img/Anonimo.jpeg" alt="Alunos" class="student-photo" />
                     </div></td>
                    <td>@aluno.Nome @aluno.Sobrenome</td>
                    <td>@aluno.Email</td>
                    <td>@aluno.Matricula</td>
                    <td>@aluno.Curso</td>
                    <td>@(aluno.Disciplinas.Any() ? string.Join(", ", aluno.Disciplinas.Select(d => d.Nome)) : "-")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@aluno.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@aluno.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Nenhum aluno encontrado.</td>
            </tr>       
        }
    </tbody>
</table>
